<Window x:Class="GingerPaw.Overlay.PillOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        ShowActivated="False">
    <!-- Outer margin so the purr/bounce scale animations never clip at the window edge,
         mirroring the Mac panel's `container` wrapper around the pill. -->
    <Grid Margin="8">
        <Border x:Name="Pill" CornerRadius="22" Height="44" Padding="18,0">
            <Border.RenderTransform>
                <ScaleTransform x:Name="PillScale" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5" />
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="19" Height="19" Margin="0,0,8,0">
                    <TextBlock x:Name="IconGlyph"
                               FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- Simplified paw glyph shown only while Recording (skip pixel-perfect
                         paw art per plan.md — one pad + four toe ellipses is enough). -->
                    <Canvas x:Name="PawIcon" Width="19" Height="19" Visibility="Collapsed">
                        <Ellipse Canvas.Left="3" Canvas.Top="7" Width="13" Height="10" Fill="#F4C89B" />
                        <Ellipse Canvas.Left="1" Canvas.Top="3" Width="4.5" Height="5.5" Fill="#F4C89B" />
                        <Ellipse Canvas.Left="5.8" Canvas.Top="0.5" Width="4.5" Height="5.5" Fill="#F4C89B" />
                        <Ellipse Canvas.Left="10.6" Canvas.Top="0.5" Width="4.5" Height="5.5" Fill="#F4C89B" />
                        <Ellipse Canvas.Left="14.3" Canvas.Top="3" Width="4.5" Height="5.5" Fill="#F4C89B" />
                    </Canvas>

                    <!-- Three-bar pulse shown while Processing — simplified stand-in for the
                         Mac's animated `.variableColor.iterative` waveform symbol effect. -->
                    <StackPanel x:Name="BarsIcon" Orientation="Horizontal" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Visibility="Collapsed">
                        <Rectangle x:Name="Bar1" Width="3" Height="14" Fill="White" Margin="0,0,2,0" Opacity="0.4" />
                        <Rectangle x:Name="Bar2" Width="3" Height="14" Fill="White" Margin="0,0,2,0" Opacity="0.4" />
                        <Rectangle x:Name="Bar3" Width="3" Height="14" Fill="White" Opacity="0.4" />
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold" Foreground="White"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
